---
import "../index.css";

interface Props {
  fullName: string;
  keywords: string;
  profileImage: string;
  metaDescription: string;
}

const { fullName, metaDescription, profileImage, keywords } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <script>
      document.documentElement.classList.add("js");
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullName}</title>
    <meta name="author" content={fullName} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={Astro.url.href} />
    <meta name="keywords" content={keywords} />
    <meta property="og:title" content={fullName} />
    <meta name="twitter:title" content={fullName} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content={fullName} />
    <meta name="description" content={metaDescription} />
    <meta property="og:description" content={metaDescription} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="theme-color" content="#f3e8c9" />
    <meta property="og:image" content={profileImage} />
    <meta name="twitter:image" content={profileImage} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/ico" href={`${Astro.url.href}/favicon.ico`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&family=Inter:wght@100..900&family=Space+Mono:ital,wght@0,400;0,700;1,400;1,700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="scanlines"></div>
    <slot />
    <script>
      const obs = new IntersectionObserver(
        (entries) =>
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add("is-visible");
              obs.unobserve(e.target);
            }
          }),
        { threshold: 0.12, rootMargin: "-40px 0px" },
      );
      document
        .querySelectorAll("[data-animate], [data-stagger]")
        .forEach((el) => obs.observe(el));
    </script>
  </body>
</html>
